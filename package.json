{
  "name": "surpresso-pwa",
  "version": "1.0.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "prisma:generate": "prisma generate --schema backend/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate deploy --schema backend/prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema backend/prisma/schema.prisma",
    "prisma:seed": "node backend/prisma/seed.js"
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "express": "^4.18.2",
    "express-session": "^1.18.2",
    "form-data": "^4.0.5",
    "jsonwebtoken": "^9.0.3",
    "node-fetch": "^3.3.2",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^4.10.38",
    "@prisma/client": "^6.7.0"
  },
  "devDependencies": {
    "prisma": "^6.7.0"
  },
  "prisma": {
    "schema": "backend/prisma/schema.prisma"
  }
}
