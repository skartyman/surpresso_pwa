generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum WorkMode {
  field
  inhouse
  hybrid
}

enum OwnerType {
  company
  client
}

enum ClientServiceType {
  service_contract
  regular_client
}

enum EquipmentType {
  grinder
  pro_coffee
  auto_coffee
  filter_system
}

enum EquipmentServiceStatus {
  accepted
  in_progress
  testing
  ready
  processed
  closed
  cancelled
}

enum EquipmentCommercialStatus {
  issued_to_client
  ready_for_issue
  ready_for_rent
  out_on_rent
  out_on_replacement
  ready_for_sale
  reserved_for_rent
  reserved_for_sale
  sold
}

enum EquipmentPlacement {
  workshop
  at_location
  on_rent
  on_replacement
  sold
}

enum WorkshopStage {
  arrived_waiting
  in_progress
  testing
  ready
}

enum ServiceRequestStatus {
  new
  assigned
  taken_in_work
  ready_for_qc
  on_service_head_control
  to_director
  invoiced
  closed
  cancelled
}

enum ServiceIntakeType {
  client_repair
  after_rent
  after_replacement
  new_purchase
  manual_intake
}

enum MediaKind {
  photo
  video
  document
}

enum InvoiceStatus {
  not_required
  pending
  issued
  paid
  cancelled
}

model User {
  id                    String    @id
  fullName              String
  email                 String    @unique
  phone                 String?
  notes                 String?
  workMode              WorkMode?
  capacity              Int?      @default(6)
  maxCritical           Int?      @default(2)
  priorityWeight        Int?      @default(0)
  canTakeUrgent         Boolean   @default(true)
  canTakeFieldRequests  Boolean   @default(false)
  passwordHash          String
  role                  String
  positionTitle         String    @default("")
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  assignedRequests      ServiceRequest[]                  @relation("AssignedUserRequests")
  assignedByRequests    ServiceRequest[]                  @relation("AssignmentByUserRequests")
  requestStatusUpdates  ServiceRequestStatusHistory[]     @relation("StatusChangedByUser")
  assignmentFromHistory ServiceRequestAssignmentHistory[] @relation("AssignmentFromUser")
  assignmentToHistory   ServiceRequestAssignmentHistory[] @relation("AssignmentToUser")
  assignmentMadeHistory ServiceRequestAssignmentHistory[] @relation("AssignmentMadeByUser")
  requestInternalNotes  ServiceRequestInternalNote[]
  specializations       UserSpecialization[]
  brandSkills           UserBrandSkill[]
  zones                 UserZone[]
  assignedServiceCases  ServiceCase[]          @relation("ServiceCaseAssignedTo")
  delegatedServiceCases ServiceCase[]          @relation("ServiceCaseAssignedBy")
  processedServiceCases ServiceCase[]          @relation("ServiceCaseProcessedBy")
  uploadedServiceMedia  ServiceCaseMedia[]
  changedServiceHistory ServiceStatusHistory[]
  changedCommercialHistory CommercialStatusHistory[]
  serviceCaseNotes      ServiceCaseNote[]
  equipmentComments     EquipmentComment[]
  equipmentNotes        EquipmentNote[]
  assignedServiceTasks  ServiceTask[]    @relation("ServiceTaskAssignedTo")
  createdServiceTasks   ServiceTask[]    @relation("ServiceTaskCreatedBy")
  reportPresets         ReportPreset[]
}

model UserSpecialization {
  id               String   @id
  userId           String
  specializationKey String
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, specializationKey])
  @@index([specializationKey])
  @@index([userId])
}

model UserBrandSkill {
  id        String   @id
  userId    String
  brandKey  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, brandKey])
  @@index([brandKey])
  @@index([userId])
}

model UserZone {
  id        String   @id
  userId    String
  zoneKey   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, zoneKey])
  @@index([zoneKey])
  @@index([userId])
}


model Client {
  id             String   @id
  telegramUserId String   @unique
  companyName    String
  contactName    String
  phone          String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  equipment       Equipment[]
  serviceRequests ServiceRequest[]
  pointUsers      PointUser[]
}

model Network {
  id          String   @id
  name        String
  legalName   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  locations   Location[]
  equipment   Equipment[]
  pointUsers  PointUser[]
}

model Location {
  id           String   @id
  networkId    String
  code         String?
  name         String
  city         String?
  address      String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  network      Network  @relation(fields: [networkId], references: [id], onDelete: Cascade)
  equipment    Equipment[]
  pointUsers   PointUser[]
  serviceRequests ServiceRequest[]

  @@index([networkId])
}

model PointUser {
  id             String   @id
  telegramUserId String   @unique
  clientId       String?
  networkId      String?
  locationId     String?
  role           String
  fullName       String?
  phone          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  client         Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  network        Network?  @relation(fields: [networkId], references: [id], onDelete: SetNull)
  location       Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  serviceRequests ServiceRequest[]

  @@index([clientId])
  @@index([networkId])
  @@index([locationId])
}

model Equipment {
  id             String   @id
  clientId       String?
  networkId      String?
  locationId     String?
  type           String
  brand          String
  name           String?
  model          String?
  serial         String?
  internalNumber String?
  status         String
  ownerType          OwnerType?
  clientServiceType  ClientServiceType?
  equipmentType      EquipmentType?
  currentStatusRaw   String?
  serviceStatus      EquipmentServiceStatus?
  commercialStatus   EquipmentCommercialStatus?
  currentPlacement   EquipmentPlacement?
  workshopStage      WorkshopStage?
  clientName         String?
  clientPhone        String?
  clientLocation     String?
  companyLocation    String?
  lastComment        String?
  folderId           String?
  folderUrl          String?
  passportPdfId      String?
  passportPdfUrl     String?
  qrUrl              String?
  isActive           Boolean   @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  client          Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  network         Network?          @relation(fields: [networkId], references: [id], onDelete: SetNull)
  location        Location?         @relation(fields: [locationId], references: [id], onDelete: SetNull)
  serviceRequests ServiceRequest[]
  serviceCases    ServiceCase[]
  serviceMedia    ServiceCaseMedia[]
  serviceHistory  ServiceStatusHistory[]
  commercialHistory CommercialStatusHistory[]
  comments        EquipmentComment[]
  notes           EquipmentNote[]
  tasks           ServiceTask[]

  @@index([clientId])
  @@index([networkId])
  @@index([locationId])
  @@index([ownerType])
  @@index([clientServiceType])
  @@index([equipmentType])
  @@index([serviceStatus])
  @@index([commercialStatus])
  @@index([internalNumber])
  @@index([serial])
}

model ServiceCase {
  id                         String   @id
  equipmentId                String
  serviceRequestId           String?
  intakeType                 ServiceIntakeType
  serviceStatus              EquipmentServiceStatus
  commercialStatusAfter      EquipmentCommercialStatus?
  priority                   String?
  problemDescription         String?
  damageDescription          String?
  intakeComment              String?
  closingComment             String?
  ownerTypeSnapshot          OwnerType?
  clientServiceTypeSnapshot  ClientServiceType?
  clientNameSnapshot         String?
  clientPhoneSnapshot        String?
  clientLocationSnapshot     String?
  companyLocationSnapshot    String?
  modelSnapshot              String?
  serialNumberSnapshot       String?
  internalNumberSnapshot     String?
  equipmentNameSnapshot      String?
  assignedToUserId           String?
  assignedByUserId           String?
  processedByUserId          String?
  invoiceNumber              String?
  invoiceStatus              InvoiceStatus?
  acceptedAt                 DateTime?
  assignedAt                 DateTime?
  testingAt                  DateTime?
  readyAt                    DateTime?
  processedAt                DateTime?
  closedAt                   DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  equipment       Equipment           @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  serviceRequest  ServiceRequest?     @relation(fields: [serviceRequestId], references: [id], onDelete: SetNull)
  assignedToUser  User?               @relation("ServiceCaseAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  assignedByUser  User?               @relation("ServiceCaseAssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)
  processedByUser User?               @relation("ServiceCaseProcessedBy", fields: [processedByUserId], references: [id], onDelete: SetNull)
  media           ServiceCaseMedia[]
  history         ServiceStatusHistory[]
  notes           ServiceCaseNote[]
  tasks           ServiceTask[]
  commercialHistory CommercialStatusHistory[]

  @@index([equipmentId])
  @@index([serviceRequestId])
  @@index([serviceStatus])
  @@index([assignedToUserId])
  @@index([acceptedAt])
}

model ServiceCaseMedia {
  id               String   @id
  equipmentId      String
  serviceCaseId    String?
  kind             MediaKind
  filePath         String
  fileUrl          String
  mimeType         String?
  originalName     String?
  fileSize         Int      @default(0)
  caption          String?
  uploadedByUserId String?
  createdAt        DateTime @default(now())

  equipment      Equipment    @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  serviceCase    ServiceCase? @relation(fields: [serviceCaseId], references: [id], onDelete: SetNull)
  uploadedByUser User?        @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([equipmentId])
  @@index([serviceCaseId])
  @@index([uploadedByUserId])
  @@map("EquipmentMedia")
}

model ServiceStatusHistory {
  id                 String   @id
  equipmentId        String
  serviceCaseId      String?
  fromStatusRaw      String?
  toStatusRaw        String
  fromServiceStatus  EquipmentServiceStatus?
  toServiceStatus    EquipmentServiceStatus?
  comment            String?
  actorLabel         String?
  changedByUserId    String?
  changedAt          DateTime @default(now())

  equipment     Equipment    @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  serviceCase   ServiceCase? @relation(fields: [serviceCaseId], references: [id], onDelete: SetNull)
  changedByUser User?        @relation(fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([equipmentId])
  @@index([serviceCaseId])
  @@index([changedByUserId])
}

model CommercialStatusHistory {
  id                       String   @id
  equipmentId              String
  serviceCaseId            String?
  fromCommercialStatus     EquipmentCommercialStatus?
  toCommercialStatus       EquipmentCommercialStatus
  comment                  String?
  actorLabel               String?
  changedByUserId          String?
  changedAt                DateTime @default(now())

  equipment     Equipment    @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  serviceCase   ServiceCase? @relation(fields: [serviceCaseId], references: [id], onDelete: SetNull)
  changedByUser User?        @relation(fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([equipmentId])
  @@index([serviceCaseId])
  @@index([changedByUserId])
}

model ServiceCaseNote {
  id            String   @id
  serviceCaseId String
  authorUserId  String?
  body          String
  isInternal    Boolean  @default(true)
  createdAt     DateTime @default(now())

  serviceCase ServiceCase @relation(fields: [serviceCaseId], references: [id], onDelete: Cascade)
  authorUser  User?       @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([serviceCaseId])
  @@index([authorUserId])
}

model EquipmentComment {
  id            String   @id
  equipmentId   String
  authorUserId  String?
  body          String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  authorUser User?    @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([equipmentId])
  @@index([authorUserId])
}

model EquipmentNote {
  id            String   @id
  equipmentId   String
  authorUserId  String?
  body          String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  authorUser User?    @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([equipmentId])
  @@index([authorUserId])
}

model ServiceTask {
  id               String   @id
  serviceCaseId    String?
  equipmentId      String?
  title            String
  description      String?
  status           String
  assignedToUserId String?
  createdByUserId  String?
  dueAt            DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  serviceCase     ServiceCase? @relation(fields: [serviceCaseId], references: [id], onDelete: SetNull)
  equipment       Equipment?   @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  assignedToUser  User?        @relation("ServiceTaskAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  createdByUser   User?        @relation("ServiceTaskCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([serviceCaseId])
  @@index([equipmentId])
  @@index([status])
  @@index([assignedToUserId])
}

model NotificationLog {
  id              String   @id
  channel         String
  recipientRole   String
  recipientChatId String
  digestType      String
  severity        String
  payloadHash     String
  payloadPreview  String?
  status          String
  sentAt          DateTime?
  errorMessage    String?
  retryCount      Int      @default(0)
  triggerType     String   @default("manual")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([channel, recipientRole, digestType])
  @@index([recipientChatId, payloadHash, createdAt])
  @@index([status, createdAt])
}

model ReportExportHistory {
  id         String   @id
  reportType String
  format     String
  triggerType String
  requestedByRole String?
  requestedByUserId String?
  filtersJson String?
  status     String
  createdAt  DateTime @default(now())

  @@index([reportType, createdAt])
  @@index([triggerType, createdAt])
}

model ReportPreset {
  id           String   @id
  key          String
  title        String
  reportType   String
  filtersJson  String
  isSystem     Boolean  @default(false)
  ownerRole    String?
  ownerUserId  String?
  createdByUserId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdByUser User? @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([key])
  @@index([reportType])
  @@index([ownerRole])
}

model ServiceRequest {
  id                 String   @id
  type               String   @default("service_repair")
  clientId           String
  pointUserId        String?
  locationId         String?
  equipmentId        String?
  title              String   @default("")
  category           String
  description        String
  urgency            String
  canOperateNow      Boolean
  status             ServiceRequestStatus
  assignedDepartment String   @default("service")
  source             String
  assignedToUserId   String?
  assignedByUserId   String?
  assignedAt         DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  client         Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  pointUser      PointUser?            @relation(fields: [pointUserId], references: [id], onDelete: SetNull)
  location       Location?             @relation(fields: [locationId], references: [id], onDelete: SetNull)
  equipment      Equipment?            @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  assignedToUser User?                 @relation("AssignedUserRequests", fields: [assignedToUserId], references: [id])
  assignedByUser User?                 @relation("AssignmentByUserRequests", fields: [assignedByUserId], references: [id], onDelete: SetNull)
  media          ServiceRequestMedia[]
  history        ServiceRequestStatusHistory[]
  notes          ServiceRequestInternalNote[]
  assignmentHistory ServiceRequestAssignmentHistory[]
  serviceCases   ServiceCase[]

  @@index([clientId])
  @@index([pointUserId])
  @@index([locationId])
  @@index([equipmentId])
  @@index([assignedToUserId])
  @@index([assignedByUserId])
}

model ServiceRequestStatusHistory {
  id               String   @id
  serviceRequestId String
  previousStatus   String
  nextStatus       String
  changedByUserId  String?
  changedByRole    String?
  comment          String?
  createdAt        DateTime @default(now())

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  changedByUser  User?          @relation("StatusChangedByUser", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([serviceRequestId])
  @@index([changedByUserId])
}

model ServiceRequestInternalNote {
  id               String   @id
  serviceRequestId String
  authorId         String
  authorRole       String
  text             String
  createdAt        DateTime @default(now())

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  author         User           @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([serviceRequestId])
  @@index([authorId])
}


model ServiceRequestAssignmentHistory {
  id               String   @id
  serviceRequestId String
  fromUserId       String?
  toUserId         String
  assignedByUserId String
  comment          String?
  createdAt        DateTime @default(now())

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  fromUser      User?          @relation("AssignmentFromUser", fields: [fromUserId], references: [id], onDelete: SetNull)
  toUser        User           @relation("AssignmentToUser", fields: [toUserId], references: [id], onDelete: Cascade)
  assignedByUser User          @relation("AssignmentMadeByUser", fields: [assignedByUserId], references: [id], onDelete: Cascade)

  @@index([serviceRequestId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([assignedByUserId])
}

model ServiceRequestMedia {
  id               String   @id
  serviceRequestId String
  type             String
  fileId           String?
  fileUrl          String
  previewUrl       String?
  mimeType         String?
  originalName     String?
  size             Int      @default(0)
  createdAt        DateTime @default(now())

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)

  @@index([serviceRequestId])
}
